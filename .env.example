# ─────────────────────────────────────────────────────────────────────────────
# API Scanner Pro — Environment Configuration
# Copy to .env and fill in real values before running
# ─────────────────────────────────────────────────────────────────────────────

# ── API Security ──────────────────────────────────────────────────────────────
SCANNER_API_KEY=change-me-in-production

# ── CORS — restrict to your frontend domain(s) in production ─────────────────
# Examples:
#   CORS_ORIGINS=https://app.example.com
#   CORS_ORIGINS=https://app.example.com,https://staging.example.com
#   CORS_ORIGINS=*   (dev only — allows all origins)
CORS_ORIGINS=*

# ── Flower Monitor ────────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change-me

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me

# ── Redis (internal — usually no need to change) ──────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Scanner Behavior ──────────────────────────────────────────────────────────
MAX_CONCURRENCY=20
SCAN_TIMEOUT=10
# ALLOW_PRIVATE=true  # Uncomment only for scanning internal/staging APIs
ALLOW_PRIVATE=false


# ── AI / Ollama (Local LLM — Free, no cloud APIs) ────────────────────────────
# URL of local Ollama server (default: host machine port 11434)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Model to use (must be pulled first: ollama pull llama3)
OLLAMA_MODEL=llama3
# Request timeout in seconds (Llama3 8B on CPU takes ~30-90s)
OLLAMA_TIMEOUT=120
# Max tokens to generate per analysis
OLLAMA_MAX_TOKENS=1024
